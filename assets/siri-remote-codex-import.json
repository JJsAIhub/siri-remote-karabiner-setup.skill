{
  "title": "Siri Remote for Codex and Chat",
  "rules": [
    {
      "description": "Use Siri Remote as a Codex/chat controller",
      "manipulators": [
        {
          "type": "basic",
          "from": { "consumer_key_code": "menu_up" },
          "to": [{ "key_code": "up_arrow" }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "menu_down" },
          "to": [{ "key_code": "down_arrow" }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "menu_left" },
          "to": [{ "key_code": "left_arrow" }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "menu_right" },
          "to": [{ "key_code": "right_arrow" }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "selection" },
          "to": [{ "key_code": "return_or_enter" }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "generic_desktop": "system_app_menu" },
          "to": [{ "key_code": "escape" }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "data_on_screen" },
          "to": [{ "key_code": "tab" }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "play_or_pause" },
          "to": [{ "key_code": "spacebar" }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "microphone" },
          "to": [{ "apple_vendor_top_case_key_code": "keyboard_fn" }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "mute" },
          "to": [{ "key_code": "caps_lock" }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "volume_increment" },
          "to": [{ "mouse_key": { "vertical_wheel": -32 } }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "volume_decrement" },
          "to": [{ "mouse_key": { "vertical_wheel": 32 } }],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 76,
                  "product_id": 789,
                  "is_consumer": true
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
